{
  "name": "native-aarch64-apple-darwin",
  "backend": "native",
  "abi_version": 1,
  "builtin": "native",
  "target": "aarch64-apple-darwin",
  "capabilities": [
    "Stdout",
    "Stdin",
    "Stderr",
    "FileRead",
    "FileWrite",
    "Clock",
    "Random",
    "Env",
    "Process",
    "Network"
  ],
  "externs": [
    {
      "path": ["platform", "io"],
      "name": "_write_stdout_utf8!",
      "params": ["String"],
      "return": "Result<Unit, PlatformError>",
      "effectful": true,
      "capabilities": ["Stdout"],
      "bindings": {
        "native": {
          "symbol": "emela_write_stdout_utf8",
          "link": ["emela_runtime"]
        }
      }
    },
    {
      "path": ["platform", "io"],
      "name": "_read_stdin_utf8!",
      "params": [],
      "return": "Result<String, PlatformError>",
      "effectful": true,
      "capabilities": ["Stdin"],
      "bindings": {
        "native": {
          "symbol": "emela_read_stdin_utf8",
          "link": ["emela_runtime"]
        }
      }
    },
    {
      "path": ["platform", "clock"],
      "name": "_now_i32!",
      "params": [],
      "return": "I32",
      "effectful": true,
      "capabilities": ["Clock"],
      "bindings": {
        "native": {
          "symbol": "emela_now_i32",
          "link": ["emela_runtime"]
        }
      }
    }
  ]
}
