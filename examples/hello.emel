-- Uses the standard library to perform real I/O. The `Io` effect is resolved
-- by the selected backend's runtime (specs 0013/0037); `std.io` is embedded in
-- the compiler (spec 0038), so no `--package` is needed.
--
--   emela build --backend js-node   examples/hello.emel | node
--   emela build --backend wasm-wasi -o hello.wasm examples/hello.emel

import std.io

fn main() -> Unit uses { Io } {
    Io.print("Hello, Emela!\n")
}
