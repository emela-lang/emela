-- Importing a sibling module file (spec 0037): imports are module-unit, and
-- the module's public functions are called in qualified form. The module path
-- is resolved relative to this file, so `import geometry` loads
-- `geometry.emel` (which declares `module geometry`).
--
--   emela check --backend js-node examples/imports/main.emel
--   emela build --backend js-node examples/imports/main.emel

import geometry

fn main() -> Int {
    geometry.square(5) + geometry.area(3, 4)
}
